{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:orbiplex:schema:inquirium-model-package-install-receipt:v1",
  "title": "Inquirium Model Package Install Receipt v1",
  "description": "Immutable lifecycle fact for one admitted local model package installation.",
  "type": "object",
  "additionalProperties": false,
  "x-dia-workflow": "project",
  "x-dia-status": "accepted",
  "x-dia-basis": ["doc/project/40-proposals/064-inquirium-implementation-recommendations.md", "doc/project/40-proposals/066-inquirium-assistant-channel.md"],
  "required": ["schema", "schema/v", "receipt/ref", "package/ref", "manifest/digest", "state", "authority/ref", "asset/refs", "installed-at", "trace/ref"],
  "properties": {
    "schema": { "const": "inquirium.model-package.install-receipt.v1" },
    "schema/v": { "const": 1 },
    "receipt/ref": { "type": "string", "pattern": "^model-install-receipt/.+$", "maxLength": 512 },
    "package/ref": { "type": "string", "pattern": "^model-package/.+$", "maxLength": 512 },
    "manifest/digest": { "type": "string", "pattern": "^sha256:[A-Za-z0-9_-]{43}$" },
    "state": { "enum": ["installed", "verified", "failed", "removed"] },
    "authority/ref": { "type": "string", "pattern": "^authority/.+$", "maxLength": 512 },
    "asset/refs": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "pattern": "^model-asset:sha256:[A-Za-z0-9_-]{43}$" } },
    "installed-at": { "type": "string", "format": "date-time" },
    "verified-at": { "type": "string", "format": "date-time" },
    "finished-at": { "type": "string", "format": "date-time" },
    "failure/code": { "type": "string", "minLength": 1, "maxLength": 256 },
    "trace/ref": { "type": "string", "pattern": "^trace/.+$", "maxLength": 512 }
  }
}
