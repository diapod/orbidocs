{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:orbiplex:schema:sensorium-virt.host.request:v1",
  "title": "Sensorium Virt Host Request v1",
  "description": "Bounded internal request envelope for daemon-owned Sensorium Virt host authority.",
  "type": "object",
  "additionalProperties": false,
  "x-dia-workflow": "project",
  "x-dia-status": "draft",
  "x-dia-basis": [
    "doc/project/40-proposals/071-sensorium-workbench.md"
  ],
  "required": [
    "schema",
    "schema/v",
    "operation",
    "payload"
  ],
  "properties": {
    "schema": {
      "const": "sensorium-virt.host.request.v1"
    },
    "schema/v": {
      "const": 1
    },
    "operation": {
      "enum": [
        "fixture.prepare",
        "vfkit.allocate",
        "environment.start",
        "environment.inspect",
        "environment.drain",
        "environment.teardown",
        "environment.recover",
        "guest.invoke",
        "host.reconcile"
      ]
    },
    "payload": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": {
            "const": "fixture.prepare"
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/fixturePrepare"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "guest.invoke"
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/guestInvoke"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "vfkit.allocate"
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/vfkitAllocate"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "enum": [
              "environment.inspect",
              "environment.start",
              "environment.drain",
              "environment.teardown",
              "environment.recover"
            ]
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/environmentBinding"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "host.reconcile"
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/emptyPayload"
          }
        }
      }
    }
  ],
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "not": {
        "pattern": "\\u0000"
      }
    },
    "fixturePrepare": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source/path",
        "workspace/ref",
        "root/ref",
        "operational/context",
        "operational/context-policy-ref",
        "files/max",
        "bytes/max"
      ],
      "properties": {
        "source/path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "not": {
            "pattern": "\\u0000"
          }
        },
        "workspace/ref": {
          "$ref": "#/$defs/ref"
        },
        "root/ref": {
          "$ref": "#/$defs/ref"
        },
        "idempotency/key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "not": {
            "pattern": "\\u0000"
          }
        },
        "operational/context": {
          "$ref": "sensorium-operational-context.v1.schema.json"
        },
        "operational/context-policy-ref": {
          "$ref": "#/$defs/ref"
        },
        "files/max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024
        },
        "bytes/max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16777216
        }
      }
    },
    "environmentBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment/ref",
        "source/generation-ref"
      ],
      "properties": {
        "environment/ref": {
          "$ref": "#/$defs/ref"
        },
        "source/generation-ref": {
          "$ref": "#/$defs/ref"
        }
      }
    },
    "guestInvoke": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment/ref",
        "source/generation-ref",
        "guest/request",
        "timeout-ms"
      ],
      "properties": {
        "environment/ref": {
          "$ref": "#/$defs/ref"
        },
        "source/generation-ref": {
          "$ref": "#/$defs/ref"
        },
        "guest/request": {
          "$ref": "#/$defs/guestRequest"
        },
        "transfer/base64": {
          "type": "string",
          "maxLength": 699052,
          "contentEncoding": "base64"
        },
        "timeout-ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "guest/request": {
                "properties": {
                  "operation/kind": {
                    "const": "patch-stage"
                  }
                },
                "required": [
                  "operation/kind"
                ]
              }
            },
            "required": [
              "guest/request"
            ]
          },
          "then": {
            "required": [
              "transfer/base64"
            ]
          },
          "else": {
            "not": {
              "required": [
                "transfer/base64"
              ]
            }
          }
        }
      ]
    },
    "guestRequest": {
      "oneOf": [
        {
          "$ref": "#/$defs/guestSpawnProcess"
        },
        {
          "$ref": "#/$defs/guestOpenPty"
        },
        {
          "$ref": "#/$defs/guestTerminalInput"
        },
        {
          "$ref": "#/$defs/guestTerminalResize"
        },
        {
          "$ref": "#/$defs/guestTerminalSignal"
        },
        {
          "$ref": "#/$defs/guestFileSnapshot"
        },
        {
          "$ref": "#/$defs/guestFileRead"
        },
        {
          "$ref": "#/$defs/guestPatchStage"
        },
        {
          "$ref": "#/$defs/guestArtifactExport"
        },
        {
          "$ref": "#/$defs/guestLifecycle"
        }
      ]
    },
    "guestArgv": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "string",
        "maxLength": 4096,
        "not": {
          "pattern": "\\u0000"
        }
      }
    },
    "guestPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "not": {
        "pattern": "\\u0000"
      }
    },
    "guestSpawnProcess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "argv",
        "cwd",
        "timeout-ms",
        "output/bytes-max"
      ],
      "properties": {
        "operation/kind": {
          "const": "spawn-process"
        },
        "argv": {
          "$ref": "#/$defs/guestArgv"
        },
        "cwd": {
          "$ref": "#/$defs/guestPath"
        },
        "timeout-ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300000
        },
        "output/bytes-max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 524288
        }
      }
    },
    "guestOpenPty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "argv",
        "cwd",
        "rows",
        "columns",
        "output/bytes-max"
      ],
      "properties": {
        "operation/kind": {
          "const": "open-pty"
        },
        "argv": {
          "$ref": "#/$defs/guestArgv"
        },
        "cwd": {
          "$ref": "#/$defs/guestPath"
        },
        "rows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "columns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "output/bytes-max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 524288
        }
      }
    },
    "guestTerminalInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "session/ref",
        "input/base64",
        "input/digest",
        "read-wait-ms"
      ],
      "properties": {
        "operation/kind": {
          "const": "terminal-input"
        },
        "session/ref": {
          "$ref": "#/$defs/ref"
        },
        "input/base64": {
          "type": "string",
          "maxLength": 87384,
          "contentEncoding": "base64"
        },
        "input/digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "read-wait-ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000
        }
      }
    },
    "guestTerminalResize": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "session/ref",
        "rows",
        "columns"
      ],
      "properties": {
        "operation/kind": {
          "const": "terminal-resize"
        },
        "session/ref": {
          "$ref": "#/$defs/ref"
        },
        "rows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "columns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        }
      }
    },
    "guestTerminalSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "session/ref",
        "signal"
      ],
      "properties": {
        "operation/kind": {
          "const": "terminal-signal"
        },
        "session/ref": {
          "$ref": "#/$defs/ref"
        },
        "signal": {
          "enum": [
            "interrupt",
            "terminate",
            "kill"
          ]
        }
      }
    },
    "guestFileSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "path",
        "entries/max"
      ],
      "properties": {
        "operation/kind": {
          "const": "file-snapshot"
        },
        "path": {
          "$ref": "#/$defs/guestPath"
        },
        "entries/max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096
        }
      }
    },
    "guestFileRead": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "path",
        "bytes/max"
      ],
      "properties": {
        "operation/kind": {
          "const": "file-read"
        },
        "path": {
          "$ref": "#/$defs/guestPath"
        },
        "bytes/max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 524288
        }
      }
    },
    "guestPatchStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "path",
        "transfer/length",
        "transfer/digest"
      ],
      "properties": {
        "operation/kind": {
          "const": "patch-stage"
        },
        "path": {
          "$ref": "#/$defs/guestPath"
        },
        "transfer/length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 524288
        },
        "transfer/digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "guestArtifactExport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind",
        "path",
        "bytes/max"
      ],
      "properties": {
        "operation/kind": {
          "const": "artifact-export"
        },
        "path": {
          "$ref": "#/$defs/guestPath"
        },
        "bytes/max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 524288
        }
      }
    },
    "guestLifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation/kind"
      ],
      "properties": {
        "operation/kind": {
          "enum": [
            "inspect",
            "quiesce",
            "shutdown"
          ]
        }
      }
    },
    "vfkitAllocate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace/ref",
        "root/ref",
        "operational/context",
        "operational/context-policy-ref",
        "limits"
      ],
      "properties": {
        "workspace/ref": {
          "$ref": "#/$defs/ref"
        },
        "root/ref": {
          "$ref": "#/$defs/ref"
        },
        "idempotency/key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "not": {
            "pattern": "\\u0000"
          }
        },
        "operational/context": {
          "$ref": "sensorium-operational-context.v1.schema.json"
        },
        "operational/context-policy-ref": {
          "$ref": "#/$defs/ref"
        },
        "limits": {
          "$ref": "#/$defs/environmentLimits"
        }
      }
    },
    "environmentLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu/vcpus",
        "memory/bytes",
        "storage/bytes",
        "processes/max",
        "operation/timeout-ms",
        "channel/frame-bytes-max",
        "channel/queue-depth-max"
      ],
      "properties": {
        "cpu/vcpus": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        },
        "memory/bytes": {
          "type": "integer",
          "minimum": 67108864,
          "maximum": 1099511627776,
          "multipleOf": 1048576
        },
        "storage/bytes": {
          "type": "integer",
          "minimum": 1048576,
          "maximum": 17592186044416
        },
        "processes/max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "operation/timeout-ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400000
        },
        "channel/frame-bytes-max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "channel/queue-depth-max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096
        }
      }
    },
    "emptyPayload": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 0
    }
  }
}
