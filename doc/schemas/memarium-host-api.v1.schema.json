{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:orbiplex:schema:memarium-host-api:v1",
  "title": "Memarium Host API v1",
  "description": "Stable wire contract for daemon-level memarium.* host capability request and response envelopes. Operations are selected by the endpoint plus the `op` field; clients MUST parse `status` programmatically and MUST NOT parse free-form `reason`.",
  "type": "object",
  "x-dia-workflow": "project",
  "x-dia-status": "accepted",
  "x-dia-basis": [
    "doc/project/40-proposals/036-memarium.md",
    "doc/project/40-proposals/047-classification-label-propagation.md",
    "doc/project/60-solutions/002-memarium/002-memarium.md"
  ],
  "oneOf": [
    { "$ref": "#/$defs/OperationEnvelope" },
    { "$ref": "#/$defs/OkResponse" },
    { "$ref": "#/$defs/ErrorResponse" }
  ],
  "$defs": {
    "OperationEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "request"],
      "properties": {
        "op": {
          "type": "string",
          "enum": [
            "get_entry",
            "query_entries",
            "get_fact",
            "query_facts",
            "write_entry",
            "write_fact",
            "space_projection",
            "all_projections",
            "get",
            "put",
            "invalidate",
            "promote",
            "forget",
            "declassify",
            "quarantine_list",
            "quarantine_accept",
            "quarantine_reject",
            "crisis_status",
            "crisis_resolve"
          ]
        },
        "request": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "op": { "const": "quarantine_list" } }, "required": ["op"] },
          "then": { "properties": { "request": { "$ref": "#/$defs/QuarantineListRequest" } } }
        },
        {
          "if": { "properties": { "op": { "enum": ["quarantine_accept", "quarantine_reject"] } }, "required": ["op"] },
          "then": { "properties": { "request": { "$ref": "#/$defs/QuarantineDecisionRequest" } } }
        }
      ]
    },
    "QuarantineListRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["space"],
      "properties": {
        "space": { "type": "string", "enum": ["personal", "community", "public", "crisis"] },
        "community_id": { "type": "string", "minLength": 1 },
        "entry_kind": { "type": "string", "minLength": 1 },
        "limit": { "type": "integer", "minimum": 0 },
        "entry_offset": { "type": "integer", "minimum": 0, "default": 0 },
        "fact_offset": { "type": "integer", "minimum": 0, "default": 0 }
      },
      "allOf": [
        {
          "if": { "properties": { "space": { "const": "community" } }, "required": ["space"] },
          "then": { "required": ["community_id"] }
        }
      ]
    },
    "QuarantineDecisionRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["space", "reason"],
      "properties": {
        "space": { "type": "string", "enum": ["personal", "community", "public", "crisis"] },
        "community_id": { "type": "string", "minLength": 1 },
        "target_kind": { "type": "string", "enum": ["entry", "fact"] },
        "target_id": { "type": "string", "minLength": 1 },
        "fact_id": { "type": "string", "minLength": 1, "description": "Deprecated compatibility alias for target_kind=fact plus target_id." },
        "entry_kind": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 2048 }
      },
      "oneOf": [
        { "required": ["target_kind", "target_id"], "not": { "required": ["fact_id"] } },
        { "required": ["fact_id"], "not": { "anyOf": [{ "required": ["target_kind"] }, { "required": ["target_id"] }] } }
      ],
      "allOf": [
        {
          "if": { "properties": { "space": { "const": "community" } }, "required": ["space"] },
          "then": { "required": ["community_id"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "entry" } }, "required": ["target_kind"] },
          "then": { "required": ["entry_kind"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "fact" } }, "required": ["target_kind"] },
          "then": { "not": { "required": ["entry_kind"] } }
        }
      ]
    },
    "OkResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "status": { "const": "ok" }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason", "retryable"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "invalid_request",
            "unsupported_op",
            "invalid_operator_reason",
            "passport_lookup_failed",
            "passport_invalid",
            "passport_expired",
            "binding_mismatch",
            "allowed_callers_mismatch",
            "no_profile_matched",
            "policy_denied",
            "revocation_stale",
            "revoked",
            "operator_only",
            "classification_missing",
            "classification_mismatch",
            "declassification_required",
            "declassification_scope_expired",
            "bound_subjects_not_public",
            "quarantined",
            "source_tier_immutable",
            "space_policy_violation",
            "promotion_denied",
            "not_found",
            "unknown_detector",
            "memarium_unavailable",
            "storage_unavailable",
            "storage_error",
            "internal_error"
          ]
        },
        "reason": { "type": "string" },
        "retryable": { "type": "boolean" },
        "audit_decision": {
          "type": "string",
          "pattern": "^denied:"
        },
        "details": true
      }
    }
  }
}
