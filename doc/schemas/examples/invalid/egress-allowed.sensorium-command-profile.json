{
  "schema": "sensorium-command-profile.v1",
  "schema/v": 1,
  "command.profile/ref": "command-profile:egress-denied",
  "executable": "cargo",
  "fixed_args": ["test"],
  "allowed_arg_prefixes": ["-p"],
  "allowed_workspace_roots": ["root:repo"],
  "env": {
    "mode": "profile-defaults-only"
  },
  "network": { "mode": "none", "egress": "internet" },
  "limits": {
    "default_timeout_ms": 30000,
    "max_timeout_ms": 120000,
    "stdout_bytes": 65536,
    "stderr_bytes": 65536
  }
}
