{
  "schema/v": "capability-authorization-policy.v1",
  "policy/id": "policy:capability-authorization:p071-workbench-mvp",
  "registry/ref": "capability-registry.v1",
  "entries": [
    {
      "capability/id": "sensorium.workbench.terminal",
      "required/grants": ["grant/workbench.terminal"],
      "caller/posture": "host-grant-required",
      "approval/mode": "operator-approved-by-default",
      "autonomy/floor": "proposed-effect",
      "coi/policy": "operator-review-required",
      "notes": "Terminal sessions and structured commands require an explicit Workbench terminal grant; raw input remains operator-only in MVP."
    },
    {
      "capability/id": "sensorium.workbench.file",
      "required/grants": ["grant/workbench.file-read"],
      "caller/posture": "host-grant-required",
      "approval/mode": "auto-with-grant",
      "autonomy/floor": "read-only",
      "coi/policy": "declaration-required",
      "notes": "File snapshot/read is bounded by workspace/root/path lease, classification, and byte caps."
    },
    {
      "capability/id": "sensorium.workbench.patch",
      "required/grants": ["grant/workbench.patch-write"],
      "caller/posture": "host-grant-required",
      "approval/mode": "operator-approved-by-default",
      "autonomy/floor": "proposed-effect",
      "coi/policy": "operator-review-required",
      "notes": "Patch/write authority requires explicit write grant, digest/provenance checks, and approval unless a narrow policy lease says otherwise."
    },
    {
      "capability/id": "sensorium.workbench.env",
      "required/grants": ["grant/workbench.environment"],
      "caller/posture": "host-grant-required",
      "approval/mode": "operator-approved-by-default",
      "autonomy/floor": "bounded-auto",
      "coi/policy": "declaration-required",
      "notes": "Environment access is scoped to backend, workspace roots, teardown policy, and resource caps; egress and credentials stay denied unless separately granted."
    },
    {
      "capability/id": "sensorium.interface.read",
      "required/grants": ["grant/sensorium.interface.read"],
      "caller/posture": "host-grant-required",
      "approval/mode": "auto-with-grant",
      "autonomy/floor": "observation-only",
      "coi/policy": "declaration-required",
      "notes": "Each read is admitted against current interface lifecycle, resource-scoped authority, exact topic classification, deadline, and batch caps."
    },
    {
      "capability/id": "sensorium.interface.subscribe",
      "required/grants": ["grant/sensorium.interface.subscribe"],
      "caller/posture": "host-grant-required",
      "approval/mode": "auto-with-grant",
      "autonomy/floor": "observation-only",
      "coi/policy": "declaration-required",
      "notes": "Subscription authority creates a bounded caller-bound lease and does not imply arbitrary one-shot read authority."
    },
    {
      "capability/id": "sensorium.interface.remote-feed",
      "required/grants": ["grant/sensorium.interface.remote-feed"],
      "caller/posture": "host-grant-required",
      "approval/mode": "auto-with-grant",
      "autonomy/floor": "observation-only",
      "coi/policy": "declaration-required",
      "notes": "Recipient-side remote-feed authority permits bounded authenticated peer egress only; every source operation still requires a separate current sensorium.interface.subscribe Passport scoped to the exact remote node and interface."
    },
    {
      "capability/id": "sensorium.interface.invoke",
      "required/grants": ["grant/sensorium.interface.invoke"],
      "caller/posture": "host-grant-required",
      "approval/mode": "auto-with-grant",
      "autonomy/floor": "bounded-auto",
      "coi/policy": "declaration-required",
      "notes": "Actuation status, control, and invoke remain resource-, method-, generation-, classification-, limit-, and lease-scoped; observation authority never implies effect authority."
    },
    {
      "capability/id": "sensorium.interface.manage",
      "required/grants": ["grant/sensorium.interface.manage"],
      "allowed/actions": ["publish", "publish-actuation", "suspend", "resume", "withdraw", "grant", "grant-actuation", "revoke", "control.preempt", "room-project-start", "room-project-stop", "room-project-inspect", "room-collaboration-publish", "room-collaboration-withdraw", "room-collaboration-inspect", "metrics", "inspect"],
      "caller/posture": "host-grant-required",
      "approval/mode": "operator-approved-by-default",
      "autonomy/floor": "proposed-effect",
      "coi/policy": "operator-review-required",
      "notes": "Source-local publication, suspension, withdrawal, grant, and revocation remain action-scoped host decisions and cannot be delegated through a Passport."
    },
    {
      "capability/id": "interaction-broker.wait",
      "required/grants": ["grant/interaction.wait"],
      "caller/posture": "host-broker-grant-required",
      "approval/mode": "auto-with-grant",
      "autonomy/floor": "observation-only",
      "coi/policy": "not-applicable",
      "notes": "Wait authority is scoped to source, deadline, cursor/condition, classification, and idempotency key."
    },
    {
      "capability/id": "interaction-broker.watch",
      "required/grants": ["grant/interaction.watch"],
      "caller/posture": "host-broker-grant-required",
      "approval/mode": "auto-with-grant",
      "autonomy/floor": "observation-only",
      "coi/policy": "not-applicable",
      "notes": "Watch authority is scoped to observation source, cursor retention window, TTL, caps, and classification. Module watches over room-event additionally require daemon-issued grant material bound to the exact room/ref."
    },
    {
      "capability/id": "interaction-broker.probe",
      "required/grants": ["grant/interaction.probe"],
      "caller/posture": "host-broker-grant-required",
      "approval/mode": "auto-with-grant",
      "autonomy/floor": "observation-only",
      "coi/policy": "not-applicable",
      "notes": "Probe authority is scoped to diagnostic target, source ownership, deadline, and result-size caps."
    },
    {
      "capability/id": "sensorium.connector.os.action",
      "required/grants": ["grant/sensorium.os.action"],
      "caller/posture": "host-grant-required",
      "approval/mode": "operator-approved-by-default",
      "autonomy/floor": "proposed-effect",
      "coi/policy": "operator-review-required",
      "notes": "Durable Sensorium OS action-catalog deltas require explicit operator consent and remain constrained by the action class, catalog validator, and host policy."
    }
  ]
}
