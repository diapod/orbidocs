{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:orbiplex:schema:sensorium-interface-terminal-resize:v1",
  "title": "Sensorium Interface Terminal Resize v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema/v", "terminal/session-ref", "rows", "cols"],
  "properties": {
    "schema": { "const": "sensorium-interface-terminal-resize.v1" },
    "schema/v": { "const": 1 },
    "terminal/session-ref": { "$ref": "#/$defs/ref" },
    "rows": { "type": "integer", "minimum": 1, "maximum": 200 },
    "cols": { "type": "integer", "minimum": 1, "maximum": 500 }
  },
  "$defs": { "ref": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[^\\s]+$" } }
}
