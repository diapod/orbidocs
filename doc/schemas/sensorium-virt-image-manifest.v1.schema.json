{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:orbiplex:schema:sensorium-virt-image-manifest:v1",
  "title": "Sensorium Virt Image Manifest v1",
  "description": "Digest-pinned logical full-system image and its backend variants.",
  "type": "object",
  "additionalProperties": false,
  "x-dia-workflow": "project",
  "x-dia-status": "draft",
  "x-dia-basis": ["doc/project/40-proposals/071-sensorium-workbench.md"],
  "required": ["schema", "schema/v", "image/ref", "userspace/rootfs-digest", "sbom/digest", "build-provenance/ref", "build-provenance/digest", "guest-agent/digest", "guest-protocol/schema-set-digest", "guest-protocol/version", "variants"],
  "properties": {
    "schema": { "const": "sensorium-virt-image-manifest.v1" },
    "schema/v": { "const": 1 },
    "image/ref": { "$ref": "#/$defs/ref" },
    "userspace/rootfs-digest": { "$ref": "#/$defs/digest" },
    "sbom/digest": { "$ref": "#/$defs/digest" },
    "build-provenance/ref": { "$ref": "#/$defs/ref" },
    "build-provenance/digest": { "$ref": "#/$defs/digest" },
    "guest-agent/digest": { "$ref": "#/$defs/digest" },
    "guest-protocol/schema-set-digest": { "$ref": "#/$defs/digest" },
    "guest-protocol/version": { "type": "integer", "const": 1 },
    "variants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["variant/ref", "backend/id", "architecture", "boot/mode", "storage/format", "artifact/ref", "artifact/digest"],
        "properties": {
          "variant/ref": { "$ref": "#/$defs/ref" },
          "backend/id": { "$ref": "#/$defs/ref" },
          "architecture": { "enum": ["x86_64", "arm64"] },
          "boot/mode": { "enum": ["none", "efi", "direct-kernel"] },
          "storage/format": { "enum": ["directory-copy", "raw", "kernel-initrd-rootfs"] },
          "artifact/ref": { "$ref": "#/$defs/ref" },
          "artifact/digest": { "$ref": "#/$defs/digest" },
          "firmware/ref": { "$ref": "#/$defs/ref" },
          "firmware/digest": { "$ref": "#/$defs/digest" },
          "kernel/ref": { "$ref": "#/$defs/ref" },
          "kernel/digest": { "$ref": "#/$defs/digest" },
          "initrd/ref": { "$ref": "#/$defs/ref" },
          "initrd/digest": { "$ref": "#/$defs/digest" }
        },
        "dependentRequired": {
          "firmware/ref": ["firmware/digest"], "firmware/digest": ["firmware/ref"],
          "kernel/ref": ["kernel/digest"], "kernel/digest": ["kernel/ref"],
          "initrd/ref": ["initrd/digest"], "initrd/digest": ["initrd/ref"]
        }
      }
    }
  },
  "$defs": {
    "ref": { "type": "string", "minLength": 1, "maxLength": 256, "not": { "pattern": "\\u0000" } },
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
