{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:orbiplex:schema:contacts.membership-changed:v1",
  "title": "ContactsMembershipChanged v1",
  "description": "Messaging-owned Layer 3 fact recording a change to the local contacts relationship class.",
  "type": "object",
  "additionalProperties": true,
  "x-dia-workflow": "project",
  "x-dia-status": "draft",
  "x-dia-basis": ["doc/project/40-proposals/060-messaging-middleware.md"],
  "required": [
    "schema",
    "schema/v",
    "fact/id",
    "event/at",
    "relationship/class",
    "change/kind",
    "subject",
    "source/ref"
  ],
  "properties": {
    "schema": { "const": "contacts.membership-changed.v1" },
    "schema/v": { "const": 1 },
    "fact/id": {
      "type": "string",
      "pattern": "^fact:contacts.membership-changed:[a-z0-9][a-z0-9:-]*$"
    },
    "event/at": { "type": "string", "format": "date-time" },
    "relationship/class": { "const": "contacts" },
    "change/kind": {
      "type": "string",
      "enum": ["added", "refreshed", "removed", "rotated", "blocked"]
    },
    "subject": { "$ref": "#/$defs/subject" },
    "source/ref": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "passport/id": {
      "type": "string",
      "pattern": "^passport:capability:"
    }
  },
  "$defs": {
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 1,
      "properties": {
        "participant/id": { "type": "string", "pattern": "^participant:" },
        "nym/id": { "type": "string", "pattern": "^nym:" },
        "routing-subject/id": { "type": "string", "pattern": "^routing:" },
        "contact-nym/id": { "type": "string", "pattern": "^contact-nym:" }
      }
    }
  }
}
