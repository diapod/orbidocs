{:component/id :orbiplex/memarium
 :component/title "Orbiplex Memarium"
 :component/type :node-attached-organ
 :component/status :done

 :summary
 "Node-attached local memory-and-knowledge organ responsible for preserving entries, facts, crisis evidence, classification policy facts, and classification-aware archival exports across the personal, community, public, and crisis memory spaces."

 :must-implement
 [{:cap/id :memory-space-policy-enforcement
   :title "Memory Space Policy Enforcement"
   :kind :policy-enforcement
   :based-on ["doc/project/40-proposals/036-memarium.md"
              "doc/project/40-proposals/047-classification-label-propagation.md"]
   :schemas ["classification.v1"
             "memarium-host-api.v1"]
   :responsibilities
   ["Represent personal, community, public, and crisis spaces as explicit policy envelopes"
    "Enforce space-specific encryption, retention, cache TTL, promotion, and forget policies"
    "Keep entries and facts append-only at the domain boundary; policy transitions are represented as facts"
    "Reject plaintext writes into encryption-required spaces"
    "Preserve source classification labels as first-class data rather than attributes or fields"]
   :status :done}

  {:cap/id :post-chain-observation
   :title "Post-Chain Observation"
   :kind :observation
   :based-on ["doc/project/40-proposals/027-middleware-peer-message-dispatch.md"
              "doc/project/40-proposals/036-memarium.md"]
   :schemas []
   :responsibilities
   ["Bridge daemon-private post-chain events into the neutral Memarium observation port"
    "Record facts from effective payloads after middleware mutation, not from original input payloads"
    "Compile and execute declarative observe rules supplied by semantic owner modules"
    "Never block, reject, drop, or rewrite peer messages from the observer position"]
   :status :done}

  {:cap/id :memarium-host-capability-api
   :title "Memarium Host Capability API"
   :kind :daemon-api
   :based-on ["doc/project/40-proposals/036-memarium.md"
              "doc/project/40-proposals/047-classification-label-propagation.md"]
   :schemas ["capability-passport.v1"
             "classification.v1"
             "memarium-host-api.v1"]
   :responsibilities
   ["Expose passport-gated host capabilities for read, write, index, cache, promote, forget, declassify, crisis status, and crisis resolve"
    "Build structured Memarium authorization targets from space, community id, entry kind, and entry id"
    "Map dispatch-gate denials to stable wire status codes and audit decision strings"
    "Use revocation sources before accepting passport-authorized operations"
    "Keep HTTP DTOs separate from runtime domain types"]
   :status :done}

  {:cap/id :classification-policy-facts
   :title "Classification Policy Facts"
   :kind :policy-enforcement
   :based-on ["doc/project/40-proposals/047-classification-label-propagation.md"
              "doc/project/40-proposals/036-memarium.md"]
   :schemas ["classification.v1"
             "memarium-host-api.v1"]
   :responsibilities
   ["Treat missing labels during the migration window as Personal plus ingress quarantine"
    "Support append-only declassification facts through the narrow memarium-declassify passport profile"
    "Support operator quarantine accept and reject facts without mutating the source record"
    "Derive effective tier and declassify trail on read/query paths"
    "Reject egress/export attempts that violate effective tier, quarantine, or public bound-subject projection rules"]
   :status :done}

  {:cap/id :crisis-space-loop
   :title "Crisis Space Loop"
   :kind :constitutional-ops
   :based-on ["doc/project/40-proposals/036-memarium.md"
              "doc/project/40-proposals/039-crisis-space-seed-v1.md"]
   :schemas ["classification.v1"
             "memarium-host-api.v1"]
   :responsibilities
   ["Apply the reviewed crisis seed synchronously during daemon startup"
    "Store autonomous detector findings as append-only crisis facts"
    "Expose crisis status as an operator-visible derived view"
    "Record operator force-resolution through an A0-gated append-only fact"
    "Keep crisis forget and promotion constrained by constitutional space policy"]
   :status :done}

  {:cap/id :local-archival-backup
   :title "Local Archival Backup"
   :kind :storage
   :based-on ["doc/project/30-stories/story-003-remote-memory-preservation.md"
              "doc/project/40-proposals/012-learning-outcomes-and-archival-contracts.md"
              "doc/project/40-proposals/036-memarium.md"
              "doc/project/40-proposals/047-classification-label-propagation.md"]
   :schemas ["archival-package.v1"
             "classification.v1"]
   :responsibilities
   ["Build local archival-package.v1 bundles from selected Memarium entries or facts"
    "Preserve classification as package data and enforce export-bound classification guards"
    "Write bundles through a staging directory and publish only after all payloads, packages, and manifest data succeed"
    "Generate package ids scoped by backup id plus item ordinal so repeated backups of the same source do not collide"
    "Expose local control endpoints for create/list/detail inspection of backup bundles"
    "Feed remote handoff control through Artifact Delivery when the operator selects an archivist target"]
   :status :done}]

 :may-implement
 [{:cap/id :memarium-context-enrichment
   :title "Memarium Context Enrichment"
   :kind :observation
   :based-on ["doc/project/40-proposals/036-memarium.md"
              "doc/project/40-proposals/027-middleware-peer-message-dispatch.md"]
   :schemas []
   :responsibilities
   ["Annotate inbound messages with cached knowledge artifacts through a PreInput adapter"
    "Return only passthrough or annotation outcomes"
    "Keep enrichment separate from dispatch admission or mutation"]
   :status :optional}

  {:cap/id :addressable-read-sidecar
   :title "Addressable Read Sidecar"
   :kind :storage
   :based-on ["doc/project/40-proposals/036-memarium.md"]
   :schemas []
   :responsibilities
   ["Materialize domain-id addressable entry and fact current projections from append-only Memarium streams"
    "Materialize forget/declassify/quarantine policy current projections without changing Memarium contracts"
    "Remain rebuildable from the append-only storage log"
    "Expose non-temporal operator diagnostics with row counts and stream checkpoints"]
   :status :done}

  {:cap/id :remote-archivist-handoff
   :title "Remote Archivist Handoff"
   :kind :protocol
   :based-on ["doc/project/30-stories/story-003-remote-memory-preservation.md"
              "doc/project/40-proposals/012-learning-outcomes-and-archival-contracts.md"
              "doc/project/40-proposals/036-memarium.md"]
   :schemas ["archival-package.v1"
             "archivist-advertisement.v1"
             "retrieval-request.v1"
             "retrieval-response.v1"]
   :responsibilities
   ["Discover or select remote archivists under policy"
    "Transmit classification-aware archival packages and retrieval requests through Artifact Delivery / INAC handoff"
    "Record handoff and retrieval results back into Memarium as append-only facts"
    "Cache retrieved material locally to avoid redundant remote retrieval"]
   :status :done}]

 :out-of-scope
 ["Federated Memarium replication between nodes"
  "Owning Agora relay semantics or topic moderation"
  "Direct model training or model-weight mutation"
  "Replacing Sealer or other AEAD-speaking callers for payload encryption"
  "Protocol-external long-term archive custody guarantees beyond submitted Artifact Delivery handoff records"]

 :consumes
 ["classification.v1"
  "memarium-host-api.v1"
  "learning-outcome.v1"
  "knowledge-artifact.v1"
  "archivist-advertisement.v1"
  "retrieval-response.v1"
  "Post-chain observations"
  "Declarative observe rules"
  "Sealed payload envelopes"]

 :produces
 ["MemariumEntry"
  "MemariumFact"
  "memarium-host-api.v1 responses"
  "classification policy facts"
  "archival-package.v1"
  "memarium-local-backup-bundle.v1 manifests"
  "archival-handoff-requested facts"
  "archival-handoff-accepted facts"
  "archival-handoff-failed facts"
  "retrieval-request.v1 Artifact Delivery envelopes"
  "archival-retrieval-requested facts"]

 :notes
 ["This catalog is solution-level. Concrete Rust crate boundaries and daemon route ownership live in the node implementation ledger."
  "Memarium host capabilities use dotted HTTP route names such as memarium.read; passport grants use namespaced-symbol vocabulary such as memarium/read."
  "The local backup and remote archivist handoff flows are control endpoints, not passport-gated memarium.* host capabilities, because they are operator-local daemon lifecycle operations."]}
