{:component/id :orbiplex/inter-node-artifact-channel
 :component/title "Inter-Node Artifact Channel (INAC)"
 :component/type :peer-protocol
 :component/status :partial

 :summary
 "Planned peer-to-peer artifact exchange channel for byte-identical transfer of
 Agora records, Memarium blobs, and Artifact Delivery-admitted artifact kinds
 over authenticated node sessions."

 :must-implement
 [{:cap/id :inac-control-plane
   :title "INAC Control Plane"
   :kind :protocol
   :based-on ["doc/project/40-proposals/042-inter-node-artifact-channel.md"
              "doc/project/60-solutions/017-inter-node-artifact-channel/017-inter-node-artifact-channel-impl.md"]
   :schemas ["inac-control.v1"
             "peer-message-invoke.v1"]
   :responsibilities
   ["Register `inac.v1` as a peer-message kind"
    "Carry `offer`, `request`, `push`, and refusal response frames"
    "Keep control messages small and auditable"
    "Reject unknown artifact kinds with `kind-not-supported`"]
   :status :partial
   :implemented ["`inac-control.v1` JSON Schema and schema-gate coverage"
                 "`node/inac-core` pure validation and refusal vocabulary"
                 "`node/inac-runtime` fail-closed runtime registry"
                 "local outbound allow gate treats empty operation/schema sets as deny-all, not wildcard authority"
                 "daemon host capability endpoints for local offer/request/push"
                 "`inac.v1` WSS peer-message kind and in-process daemon handler"
                 "Artifact Delivery remote `inac-direct` delivery over existing WSS peer sessions"
                 "Inbound WSS `push` frames feed Artifact Delivery inbound admission"
                 "Inbound WSS `offer` frames are fail-closed behind receiver-side peer allowlists"
                 "Inbound WSS `push` frames require either an explicit receiver-side peer allowlist or an inline capability passport authorized as `inac.invitation`, `inac-push@v1`, or `memarium-custody@v1`"
                 "INAC transfer decisions are persisted in a local SQLite ledger before or after Artifact Delivery admission"
                 "INAC response meta is terminated at the peer boundary in the current implementation"
                 "operator status endpoint `/v1/inac/status`"
                 "operator UI `/admin/inac` for handlers, counters, and recent refusals"]
   :remaining ["Add Matrix mailbox peer transport if asynchronous store-and-forward is needed"
               "Add raw binary-frame optimization if the current peer-message stream carrier becomes insufficient"]}

  {:cap/id :byte-identical-artifact-transfer
   :title "Byte-Identical Artifact Transfer"
   :kind :storage
   :based-on ["doc/project/40-proposals/042-inter-node-artifact-channel.md"]
   :schemas ["agora-record.v1"
             "memarium-blob.v1"]
   :responsibilities
   ["Preserve envelope bytes exactly as received"
    "Verify `record/id` or `blob/id` against canonical envelope bytes"
    "Feed received artifacts into Artifact Delivery inbound admission"
    "Avoid re-signing artifacts during transfer"]
   :status :partial
   :implemented ["`memarium-blob.v1` is schema-gated and synchronized into node contracts"
                 "inline payload byte identity is checked by `inac-core`"
                 "`push` requires exactly one payload location: inline bytes, artifact/ref, or artifact/href"
                 "`verify_artifact_bytes` checks exact full-envelope bytes for `agora-record.v1`, `memarium-blob.v1`, and future schemas before handler interpretation"
                 "Artifact Delivery in-process acceptor verifies `agora-record.v1` and re-ingests it through local Agora when available"
                 "Artifact Delivery in-process acceptor verifies `memarium-blob.v1`, recomputes `blob/id`, requires `signature.key/public`, verifies the signature, and stores an accepted custody fact through Memarium"
                 "Baseline `agora-record.v1` handler fails explicitly when local Agora is unavailable instead of silently falling back to Memarium"
                 "Baseline `memarium-blob.v1` handler rejects plaintext/private custody fail-closed unless a future explicit policy enables it"
                 "Baseline `memarium-blob.v1` custody facts are recorded in the local public Memarium space; configurable target spaces remain future custody-policy work"]
   :remaining ["Resolve additional referenced payload locations such as `artifact/href` or peer object-store refs through explicit fetch contracts before domain admission"
               "Add delegated signature support for `memarium-blob.v1` if custody/system artifact semantics later require it"]}

  {:cap/id :binary-frame-streaming
   :title "Streamed Payload Transfer"
   :kind :transport-extension
   :based-on ["doc/project/40-proposals/042-inter-node-artifact-channel.md"
              "doc/project/40-proposals/014-node-transport-and-discovery-mvp.md"]
   :schemas ["memarium-blob.v1"]
   :responsibilities
   ["Move large payload bytes outside JSON control messages"
    "Bind binary streams to `sha256:...` payload references"
    "Verify reassembled payload hashes before acceptance"
    "Support abort semantics for incomplete streams"]
   :status :partial
   :implemented ["Artifact Delivery `inac-direct` switches payloads above its inline ceiling to stream transfer"
                 "Sender emits ordered `inac.stream.chunk.v1` peer messages over the authenticated WSS peer session"
                 "Receiver stores stream chunks under `<node-data-dir>/storage/artifact-delivery/streams`, recomputes sha256 incrementally, validates `size/bytes`, and feeds a file-backed payload to AD inbound admission only after successful finalization"
                 "Malformed, oversized, interrupted, or digest-mismatched streams fail closed before any domain acceptor is invoked"]
   :remaining ["Add explicit stream abort/control frames if needed by operators"
               "Replace the peer-message JSON chunk carrier with raw binary frames if profiling shows meaningful overhead"]}

