{:component/id :orbiplex/inter-node-artifact-channel
 :component/title "Inter-Node Artifact Channel (INAC)"
 :component/type :peer-protocol
 :component/status :partial

 :summary
 "Planned peer-to-peer artifact exchange channel for byte-identical transfer of
 Agora records, Memarium blobs, and Artifact Delivery-admitted artifact kinds
 over authenticated node sessions."

 :must-implement
 [{:cap/id :inac-control-plane
   :title "INAC Control Plane"
   :kind :protocol
   :based-on ["doc/project/40-proposals/042-inter-node-artifact-channel.md"
              "doc/project/60-solutions/017-inter-node-artifact-channel/017-inter-node-artifact-channel-impl.md"]
   :schemas ["inac-control.v1"
             "peer-message-invoke.v1"]
   :responsibilities
   ["Register `inac.v1` as a peer-message kind"
    "Carry `offer`, `request`, `push`, and refusal response frames"
    "Keep control messages small and auditable"
    "Reject unknown artifact kinds with `kind-not-supported`"]
   :status :partial
   :implemented ["`inac-control.v1` JSON Schema and schema-gate coverage"
                 "`node/inac-core` pure validation and refusal vocabulary"
                 "`node/inac-runtime` fail-closed runtime registry"
                 "daemon host capability endpoints for local offer/request/push"
                 "operator status endpoint `/v1/inac/status`"
                 "operator UI `/admin/inac` for handlers, counters, and recent refusals"]
   :remaining ["Register `inac.v1` as a WSS peer-message kind"
               "Wire remote peer session dispatch"
               "Persist transfer status/idempotency beyond in-memory MVP"]}

  {:cap/id :byte-identical-artifact-transfer
   :title "Byte-Identical Artifact Transfer"
   :kind :storage
   :based-on ["doc/project/40-proposals/042-inter-node-artifact-channel.md"]
   :schemas ["agora-record.v1"
             "memarium-blob.v1"]
   :responsibilities
   ["Preserve envelope bytes exactly as received"
    "Verify `record/id` or `blob/id` against canonical envelope bytes"
    "Feed received artifacts into Artifact Delivery inbound admission"
    "Avoid re-signing artifacts during transfer"]
   :status :partial
   :implemented ["`memarium-blob.v1` is schema-gated and synchronized into node contracts"
                 "inline payload byte identity is checked by `inac-core`"
                 "`verify_artifact_bytes` checks exact full-envelope bytes for `agora-record.v1`, `memarium-blob.v1`, and future schemas before handler interpretation"]
   :remaining ["Verify domain-specific `record/id` and `blob/id` semantics inside concrete domain handlers"
               "Feed accepted artifacts into concrete domain handlers"
               "Persist accepted custody records where the receiving domain requires it"]}

  {:cap/id :binary-frame-streaming
   :title "Binary Frame Streaming"
   :kind :transport-extension
   :based-on ["doc/project/40-proposals/042-inter-node-artifact-channel.md"
              "doc/project/40-proposals/014-node-transport-and-discovery-mvp.md"]
   :schemas ["memarium-blob.v1"]
   :responsibilities
   ["Move large payload bytes outside JSON control messages"
    "Bind binary streams to `sha256:...` payload references"
    "Verify reassembled payload hashes before acceptance"
    "Support abort semantics for incomplete streams"]
   :status :todo}

  {:cap/id :artifact-authorization-gate
   :title "Artifact Authorization Gate"
   :kind :policy-enforcement
   :based-on ["doc/project/40-proposals/041-agora-ingest-attestation.md"
              "doc/project/40-proposals/042-inter-node-artifact-channel.md"]
   :schemas ["capability-passport.v1"]
   :responsibilities
   ["Authorize inbound artifact operations through shared attestation/passport policy"
    "Support general capability, custody, invitation, and attestation-only paths"
    "Apply per-peer and per-kind rate and size budgets"
    "Keep INAC from becoming a parallel authority system"]
   :status :todo}]

 :may-implement
 [{:cap/id :artifact-delivery-inac-acceptor-integration
   :title "Artifact Delivery Acceptor Integration"
   :kind :extension
   :based-on ["doc/project/40-proposals/042-inter-node-artifact-channel.md"
              "doc/project/60-solutions/023-artifact-delivery/023-artifact-delivery.md"
              "doc/project/20-memos/node-middleware-init-and-capability-reporting.md"]
   :schemas ["artifact-delivery-acceptor.v1"
             "middleware-module-report.schema.json"]
   :responsibilities
   ["Project supervised middleware declarations into Artifact Delivery inbound acceptors"
    "Project in-process component manifests into the same operator-visible route table"
    "Fail readiness when multiple authoritative acceptors claim the same artifact kind"
    "Keep INAC as a transport adapter rather than a middleware chain"]
   :status :planned}]

 :out-of-scope
 ["Public topic indexing"
  "Replacing Agora relay"
  "Replacing Memarium custody"
  "Inventing a credential format other than capability passports"]

 :consumes
 ["agora-record.v1"
  "memarium-blob.v1"
  "capability-passport.v1"]

 :produces
 ["peer-message responses"
  "accepted artifact custody records"
  "refusal codes"]

 :notes
 ["INAC has a schema-gated local MVP scaffold, but is not yet a complete peer transport."
  "The runtime fails closed without an explicit authoritative handler for an artifact kind."
  "The local host/operator surface now includes `/v1/inac/status` and `/admin/inac`; this is observability, not peer transport completion."
  "WSS peer-message wiring, binary streaming, and passport/invitation authorization remain required before production peer-to-peer artifact exchange."]}
