   ["Choose the host-owned signature verification boundary"
    "Bind revocation evidence refs to authenticated snapshot bytes"]
   :status :deferred}]

 :out-of-scope
 ["Authorizing operations from causal metadata"
  "Treating replication sources as fact authorities"
  "Replacing domain merge policy with a generic framework"
  "Marketing the first certificate suite as zero knowledge"
  "Creating a global trace transaction or nonce service"]

 :consumes
 ["domain operations and receipts"
  "signed Contact Catalog and Seed Directory facts"
  "nym certificates and revocation evidence"
  "domain-local admission policy"]

 :produces
 ["canonical causal evidence"
  "bounded replication plans and apply reports"
  "verified scoped-claim evidence"
  "redacted acceptance trace bundles"]}
