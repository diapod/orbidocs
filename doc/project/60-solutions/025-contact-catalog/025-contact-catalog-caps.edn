{:component/id :orbiplex/contact-catalog
 :component/title "Contact Catalog"
 :component/type :node-attached-runtime
 :component/status :partial

 :summary
 "Node-attached domain catalog for opt-in private contact discovery. The current
 implementation has the MVP admission and invitation-only lookup spine:
 contact-control-backed claims, privacy-preserving lookup indexes, redacted
 audit, daemon-local contacts, contact-request admission, and narrow
 messaging-receive passport issuance. Blinded/PSI lookup, route-set v2, richer
 provider policy UX, recovery semantics, and broader end-to-end transport tests
 remain post-MVP layers."

 :must-implement
 [{:cap/id :contact-catalog-claim-admission
   :title "Contact Claim Admission"
   :kind :admission
   :based-on ["doc/project/40-proposals/058-contact-catalog.md"
              "doc/project/30-stories/story-010-message-to-a-friend.md"]
   :schemas ["contact-claim.v1"
             "capability-passport.v1"]
   :responsibilities
   ["Validate contact-claim.v1 before admission"
    "Verify participant or delegated-participant claim signatures"
    "Reject node-only claim signatures"
    "Require email-control@v1 or phone-control@v1 passport evidence for email and phone claims"
    "Check passport signature, expiry, profile match, and revocation freshness"
    "Reject raw handle publication under the MVP profile"
    "Enforce purpose allowlists, expiry, revocation reference shape, and monotonic sequence numbers"
    "Store admitted claims through CatalogStore<ContactClaimRecord>"]
   :status :done}

  {:cap/id :contact-catalog-invitation-lookup
   :title "Invitation-Only Contact Lookup"
   :kind :query
   :based-on ["doc/project/40-proposals/058-contact-catalog.md"
              "doc/project/60-solutions/023-artifact-delivery/023-artifact-delivery.md"]
   :schemas ["contact-lookup-result.v1"
             "routing-subject-binding.v1"]
   :responsibilities
   ["Expose authenticated POST /v1/contact-catalog/lookups"
    "Require authenticated callers and rate limits before lookup execution"
    "Rate limit by auth fingerprint, contact-index digest, and purpose"
    "Reject raw handle-like lookup inputs"
    "Return contact-lookup-result.v1 as a route candidate or invitation-required result"
    "Prefer routing-subject, contact-nym, or invitation routes and never return root participant ids by default"
    "Record redacted lookup audit for success, no-match, ambiguous, policy-denied, and rate-limited outcomes"]
   :status :done}

  {:cap/id :contact-request-admission
   :title "Contact Request Admission"
   :kind :admission
   :based-on ["doc/project/30-stories/story-010-message-to-a-friend.md"
              "doc/project/40-proposals/057-user-and-operator-notifications.md"
              "doc/project/60-solutions/017-inter-node-artifact-channel/017-inter-node-artifact-channel.md"
              "doc/project/60-solutions/023-artifact-delivery/023-artifact-delivery.md"]
   :schemas ["contact-request.v1"
             "notification.v1"
             "notification-action.v1"
             "capability-passport.v1"]
   :responsibilities
   ["Register exactly one authoritative in-process Artifact Delivery acceptor for contact-request.v1"
    "Persist pending contact-request.v1 state in the daemon-local contact store"
    "Create durable contact-request.received notifications with accept/reject actions"
    "Issue a narrow messaging-receive@v1 capability passport on user acceptance"
    "Scope messaging-receive passports to request, sender, recipient route, contact nym, purpose, expiry, and revocation reference"
    "Record rejection without minting authority"]
   :status :partial}

  {:cap/id :local-contact-store
   :title "Local Contact Store"
   :kind :storage
   :based-on ["doc/project/40-proposals/058-contact-catalog.md"
              "doc/project/30-stories/story-010-message-to-a-friend.md"]
   :schemas ["local-contact.v1"]
   :responsibilities
   ["Store raw handles, labels, local relationship state, and pairwise nym mappings locally"
    "Keep the store unpublished by default"
    "Expose local create/list/get/patch/archive routes through the daemon"
    "Persist accepted contact-request state and local contact decisions"
    "Expose only redacted or digest-bound references to network artifacts"]
   :status :partial}]

 :may-implement
 [{:cap/id :federated-contact-catalog-peer-fetch
   :title "Federated Contact Catalog Peer Fetch"
   :kind :optional
   :based-on ["doc/project/40-proposals/058-contact-catalog.md"]
   :schemas ["contact-claim.v1"]
   :responsibilities
   ["Use ObservedCatalogStore<ContactClaimRecord> only for communities that explicitly accept a private peer/fetch federation model"
    "Preserve publisher and origin provenance"
    "Forbid raw contact handles, unsalted public hashes, and public-log-style contact projections in federated records"
    "Keep Agora out of the Contact Catalog propagation path"
    "Fetch generic ObservedRecord<ContactClaimRecord> through CatalogAdapter<T,F> when provider policy allows it"]
   :status :partial}

  {:cap/id :private-contact-lookup-protocol
   :title "Blinded or PSI Contact Lookup"
   :kind :optional
   :based-on ["doc/project/40-proposals/058-contact-catalog.md"]
   :schemas ["contact-lookup-result.v1"]
   :responsibilities
   ["Add stronger private discovery profiles after the cryptographic protocol is selected"
    "Keep contact-lookup-result.v1 stable across lookup protocol upgrades"]
   :status :deferred}

  {:cap/id :contact-catalog-provider-policy-ux
   :title "Provider Trust Policy UX"
   :kind :inspection
   :based-on ["doc/project/40-proposals/058-contact-catalog.md"
              "doc/project/40-proposals/054-user-maintained-federated-seed-directory.md"]
   :schemas []
   :responsibilities
   ["Expose trusted, uncertain, and blocked contact-catalog provider state to operators"
    "Harden Seed Directory provider refresh and trust policy beyond the current sidecar cache"
    "Make provider policy changes auditable and reversible"]
   :implemented ["Daemon/service status exposes provider trust cache and sync diagnostics"
                 "Node UI `/admin/contact-catalog` renders discovered providers and active Trust / Uncertain / Block actions over the service `PATCH /v1/contact-catalog/providers/{id}` policy endpoint"]
   :remaining ["Add durable audit/revert history for provider policy changes"]
   :status :partial}

  {:cap/id :contact-catalog-route-set-v2
   :title "Route Set v2 and Recovery Semantics"
   :kind :optional
   :based-on ["doc/project/40-proposals/058-contact-catalog.md"]
   :schemas ["contact-lookup-result.v1"
             "local-contact.v1"]
   :responsibilities
   ["Support multiple routes per contact claim beyond the MVP single selected route"
    "Define recovery and backup semantics for daemon-local contacts and pairwise nym mappings"
    "Preserve the route-candidate contract while allowing richer contact continuation state"]
   :status :planned}]

 :out-of-scope
 ["Global address book"
  "Network storage of raw personal address books"
  "Phone or email control as legal identity assurance"
  "General friend-class authorization"
  "Messaging UI or mailbox storage"
  "Seed Directory contact semantics"
  "Agora publication of Contact Catalog records, lookup indexes, routes, or relationship facts"]

 :consumes
 ["contact-claim.v1"
  "contact-request.v1"
  "local-contact.v1"
  "capability-passport.v1"
  "routing-subject-binding.v1"
  "Seed Directory provider records for contact-catalog, email-control, and phone-control"]

 :produces
 ["contact-lookup-result.v1"
  "contact-request.received notifications"
  "notification-action.v1 accept/reject actions"
  "capability-passport.v1 under messaging-receive"
  "Local contact records and contact-request state"
  "Redacted audit facts about admission, lookup, no-match, acceptance, and rejection"]

 :notes
 ["MVP lookup mode is authenticated invitation-only with strict rate limiting."
  "Raw external handles belong in the daemon-local contact store, not in network catalog records."
  "Contact-control proves control of a contact channel, not full identity assurance."
  "Contact Catalog MVP is implemented without Agora as a publication or relay dependency."
  "The current implementation uses contact-catalog-core, contact-catalog-service, daemon local contacts, the Artifact Delivery contact.request acceptor, and Node UI /admin/contact-catalog."]}
