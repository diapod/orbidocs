  {:cap/id :bounded-server-integration-tests
   :title "Overload Rejection Integration Tests"
   :kind :test
   :based-on ["doc/project/60-solutions/016-bounded-local-server-runtime/016-bounded-local-server-runtime.md"]
   :schemas []
   :responsibilities
   ["Add integration tests verifying 503 rejection under load in a real daemon context"
    "Verify shutdown drain metrics are accurate across multiple concurrent handler completions"]
   :status :planned}]

 :out-of-scope
 ["Async I/O or tokio-based handler execution — the MVP uses sync `std::thread` pools"
  "Preemptive handler shutdown — handlers must return cooperatively; the server does not kill threads"
  "Streaming response support — the `ConnectionHandler` trait does not expose a streaming interface in MVP"
  "Dynamic connection limit adjustment at runtime — the pool size is fixed at server creation"]

 :consumes
 ["std::net (TcpListener, TcpStream)"
  "std::sync (mpsc sync_channel, Arc, Mutex)"
  "std::thread (JoinHandle, spawn, park_timeout)"]

 :produces
 ["BoundedServerConfig"
  "BoundedServerHandle"
  "BoundedServerMetrics"
  "503 Service Unavailable (overload rejection)"]

 :notes
 ["This is a single-file infrastructure crate with zero external dependencies — pure `std`."
  "All four daemon surfaces (health endpoint, seed directory, agora service, peer listener) have been migrated to this primitive."
  "The crate lives at `node/bounded-server/` and is consumed as a workspace member, not a published library."
  "Thread-per-connection is explicitly accepted for MVP; an async variant is deferred to a later iteration."]}
