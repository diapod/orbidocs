{:component/id :orbiplex/bounded-local-server-runtime
 :component/title "Bounded Local Server Runtime"
 :component/type :infrastructure
 :component/status :done

 :summary
 "A shared sync TCP/HTTP mini-server primitive (`bounded-server` crate) replacing
 ad-hoc `thread::spawn` accept loops with bounded accepts, handler permits, fast
 overload rejection, first-class shutdown drain, and runtime metrics."

 :must-implement
 [{:cap/id :bounded-server-core
   :title "Bounded Server Core Contract"
   :kind :runtime
   :based-on ["doc/project/60-solutions/016-bounded-local-server-runtime/016-bounded-local-server-runtime.md"
              "doc/project/60-solutions/000-node/000-node.md"]
   :schemas []
   :responsibilities
   ["Provide `BoundedServerConfig` with a resource contract: `max_connections`, per-socket read/write timeouts, handler timeout, shutdown grace period, backoff intervals"
    "Provide `BoundedServerHandle` with `local_addr`, `stop()`, `wait()`, `stop_token()`, and `metrics()` snapshot"
    "Provide `ConnectionHandler` trait with single-method handler interface — each accepted connection acquires a permit, released automatically on handler return"
    "Use a fixed-size thread pool pulling from a bounded `sync_channel` of depth `max_connections`"
    "Return fast HTTP 503 on overload before spawning a thread — no thread is spawned for rejected connections"
    "Catch handler panics at the per-connection boundary, count as `handler_errors_total`, and continue serving"]
   :status :done}

  {:cap/id :bounded-server-shutdown
   :title "Cooperative Shutdown Drain"
   :kind :runtime
   :based-on ["doc/project/60-solutions/016-bounded-local-server-runtime/016-bounded-local-server-runtime.md"]
   :schemas []
   :responsibilities
   ["Close the accept loop on stop signal; workers poll a shared stop flag and exit within ~250ms"
    "Wait for all worker threads to return after the stop signal — cooperative, not preemptive"
    "Record `shutdown_drain_ms` from accept-loop exit to last worker return as an operational metric"
    "Handle channel disconnect: workers notice `RecvTimeoutError::Disconnected` and exit gracefully"
    "Handle accept errors: log to `last_accept_error`, sleep for `accept_error_backoff`, and retry"]
   :status :done}

  {:cap/id :bounded-server-metrics
   :title "Bounded Server Runtime Metrics"
   :kind :inspection
   :based-on ["doc/project/60-solutions/016-bounded-local-server-runtime/016-bounded-local-server-runtime.md"]
   :schemas []
   :responsibilities
   ["Expose `active_connections`, `accepted_total`, `rejected_over_capacity_total` as counters"
    "Expose `handler_errors_total`, `shutdown_drain_ms` as operational signals"
    "Expose `last_accept_error` and `last_handler_error` for diagnostics"
    "Keep metrics behind a snapshot so callers read consistent values without contending on per-connection counters"]
   :status :done}

  {:cap/id :daemon-surface-migration
   :title "Daemon Surface Migration to Bounded Server"
   :kind :daemon-api
   :based-on ["doc/project/60-solutions/016-bounded-local-server-runtime/016-bounded-local-server-runtime.md"
              "doc/project/60-solutions/000-node/000-node.md"
              "doc/project/60-solutions/008-agora/008-agora.md"]
   :schemas []
   :responsibilities
   ["Migrate daemon health endpoint from unbounded accept loop to `bounded-server`"
    "Migrate embedded Rust Seed Directory server to `bounded-server`"
    "Migrate Agora service standalone binary to `bounded-server`"
    "Migrate daemon peer listener from unbounded accept loop to `bounded-server`"
    "Keep each surface independently configured while sharing the same crate and runtime contract"]
   :status :done}]

