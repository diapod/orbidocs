{:component/id :orbiplex/messaging-middleware
 :component/title "Messaging Middleware"
 :component/type :node-attached-runtime
 :component/status :hard-mvp-done

 :summary
 "Node-attached personal messaging runtime for Proposal 060: inbound
 message-envelope.v1 admission, outbound contact permission and private-direct
 delivery, messaging-receive@v1 receive-consent passports, Maildir plus SQLite
 mailbox state, bounded Memarium facts, Pseudonym Vault recovery records, and a
 thin Node UI. Read/unread state is synchronized by messaging.flag.v1 replay.
 Body encryption, group messaging, and live multi-device mailbox-state push are
 post-MVP."

 :must-implement
 [{:cap/id :messaging-receive-passport-profile
   :title "messaging-receive@v1 Passport Profile"
   :kind :capability
   :based-on ["doc/project/40-proposals/060-messaging-middleware.md"
              "doc/project/60-solutions/025-contact-catalog/025-contact-catalog.md"]
   :schemas ["capability-passport.v1"]
   :responsibilities
   ["Use capability id messaging-receive and canonical grant messaging/receive"
    "Use the existing MessagingReceiveProfileV1 shape from node/capability"
    "Scope receive consent by request/id, sender subjects, recipient routes, contact nym id, purposes, revocation freshness, and optional limits"
    "Check receiver-side revocation state for inline passports before persistence"
    "Default max revocation staleness to 300 seconds"
    "Reject alternate messaging receive profile shapes"]
   :status :done}

  {:cap/id :messaging-service-runtime
   :title "Supervised Messaging Service"
   :kind :service
   :based-on ["doc/project/40-proposals/060-messaging-middleware.md"]
   :schemas ["message-envelope.v1"
             "messaging.flag.v1"]
   :responsibilities
   ["Expose authenticated status, inbound accept, outbound queue, mailbox, message, retry, process, pending-fact replay, retention, crisis, and reindex endpoints"
    "Store Layer 1 message bodies in Maildir and Layer 2 indexes in SQLite"
    "Keep outbound bodies as Maildir draft records instead of long SQLite text"
    "Fail closed against receiver-side revocation snapshots before persisting inline messaging-receive passports"
    "Run reindex as remote Memarium replay, local Layer 3 replay, Maildir walk, and FTS5 rebuild"
    "Store and replay read/unread state through messaging.flag.v1 and a rebuildable SQLite flag projection"
    "Use PRAGMA user_version migrations for storage evolution"
    "Stay disabled by default in bundled daemon config"]
   :status :done}

  {:cap/id :contactability-and-local-contacts
   :title "Contactability Drafts And Local Contacts"
   :kind :ux-authority-boundary
   :based-on ["doc/project/40-proposals/060-messaging-middleware.md"
              "doc/project/40-proposals/061-contact-attestation-service.md"
              "doc/project/60-solutions/025-contact-catalog/025-contact-catalog.md"]
   :schemas ["local-contact.v1"
             "contact-attestation-request.v1"
             "contact-attestation-result.v1"]
   :responsibilities
   ["Expose daemon contactability draft, options, challenge/redeem, passport import, and publish endpoints for the Story-010 operator path"
    "Keep local contacts as daemon-local UX and continuity projections rather than network evidence"
    "Store labels, metadata, handle digests, and active/rotated pairwise contact-nym mappings"
    "Validate local-contact import/export and contact-attestation request/result boundaries through schema-gate"
    "Discover trusted/fresh attestation providers through Seed Directory before challenge/redeem"
    "Use the separate attestation-service role for email-control and phone-control acquisition"]
   :status :done}

  {:cap/id :outbound-contact-and-delivery
   :title "Outbound Contact Permission and Delivery"
   :kind :workflow
   :based-on ["doc/project/60-solutions/023-artifact-delivery/023-artifact-delivery.md"
              "doc/project/60-solutions/025-contact-catalog/025-contact-catalog.md"]
   :schemas ["contact-request.v1"
             "artifact-delivery-envelope.v1"
             "message-envelope.v1"]
   :responsibilities
   ["Send signed contact-request.v1 artifacts through contact lookup for recipient handles"
    "Derive sender participant identity from host signer key material rather than service-local placeholders"
    "Create a fresh daemon-owned routing-subject reply route for contact requests"
    "Wait for capability.passport.lookup to return a usable messaging-receive passport"
    "Promote concrete contact-lookup-result.v1 messaging routes and terminally fail no-match or policy-denied results"
    "Sign outbound message-envelope.v1 artifacts through signer.sign under signing/messaging-send"
    "Deliver ready messages through artifact.delivery.send as private-direct"
    "Retry transient host failures and terminally fail schema, conflict, or scope refusals"]
   :status :done}

  {:cap/id :inbound-policy-and-mailbox-resolution
   :title "Inbound Policy and Mailbox Resolution"
   :kind :policy
   :based-on ["doc/project/40-proposals/060-messaging-middleware.md"]
   :schemas ["message-envelope.v1"
             "local-recipient-mailbox-resolve.v1"]
   :responsibilities
   ["Always call local-recipient-mailbox.resolve before persistence"
    "Enforce passport_matches_message for presented messaging-receive passports"
    "Enforce active contacts membership or first valid accepted-contact-request passport"
    "Refuse missing consent as contacts-policy-denied without sender-visible mailbox oracle"
    "Fallback node-id or routing-subject messages without local evidence to the operator mailbox"]
   :status :done}

  {:cap/id :local-participant-handle-ownership
   :title "Local Participant Handle Ownership"
   :kind :authority
   :based-on ["doc/project/40-proposals/060-messaging-middleware.md"
              "doc/project/60-solutions/025-contact-catalog/025-contact-catalog.md"]
   :schemas ["local-recipient-mailbox-resolve.v1"]
   :responsibilities
   ["Store local participant public-handle ownership separately from address-book contacts"
    "Track handle kind, handle digest, participant id, evidence ref, evidence status, and timestamps"
    "Expose daemon control endpoints to list, add, and delete local participant handles"
    "Return verified only for fresh contact-control evidence and mapped for ordinary local projections"]
   :status :done}

  {:cap/id :layer-three-facts-and-recovery
   :title "Layer 3 Facts and Recovery"
   :kind :recovery
   :based-on ["doc/project/60-solutions/026-pseudonym-vault-and-key-roles/026-pseudonym-vault-and-key-roles.md"]
   :schemas ["contacts.membership-changed.v1"
             "messaging.passport-issued.v1"
             "messaging.passport-revoked.v1"
             "messaging.retention-decided.v1"
             "messaging.crisis-marked.v1"
             "messaging.flag.v1"]
   :responsibilities
   ["Write bounded messaging facts through memarium.write"
    "Store failed fact writes in pending_facts and expose degraded status"
    "Replay pending facts idempotently"
    "Replay remote Memarium messaging facts during reindex before local pending facts and Maildir walk"
    "Replay messaging.flag.v1 to restore read/unread state across device/reindex recovery"
    "Mirror contacts membership and receive-passport references through identity.messaging-recovery.mirror"
    "Export and replay local contact, pairwise mapping, and messaging mirror recovery bundles without reactivating revoked or archived mappings"
    "Persist accepted recovery mirror records in the daemon-local durable mirror table and seal/replay local recovery bundles through pseudonym-vault.v1"
    "Reindex SQLite from Maildir and Layer 3 facts"]
   :status :done}

  {:cap/id :messaging-node-ui
   :title "Node UI Messaging Surface"
   :kind :ui
   :based-on ["doc/project/40-proposals/060-messaging-middleware.md"]
   :schemas ["local-contact.v1"]
   :responsibilities
   ["Expose /admin/messaging for status, contactability drafts, provider challenge/redeem, compose, inbox, read/unread actions, outbox, message detail, pending facts, and recovery diagnostics"
    "Render local-contact based unknown-recipient warnings before contact-request flow"
    "Use daemon-proxied /v1/messaging/* APIs rather than duplicating domain logic"
    "Handle mailbox.open notification actions by opening message detail without mutating consent state"]
   :status :done}]

 :may-implement
 [{:cap/id :html-message-rendering
   :title "HTML Message Rendering"
   :kind :optional
   :based-on ["doc/project/40-proposals/060-messaging-middleware.md"]
   :schemas ["message-envelope.v1"]
   :responsibilities
   ["Render sanitized HTML body parts after the text/plain MVP is stable"
    "Keep active content disabled by default"
    "Expose operator-visible source/preview switching"]
   :status :deferred}

  {:cap/id :group-messaging
   :title "Group Messaging"
   :kind :optional
   :based-on ["doc/project/40-proposals/060-messaging-middleware.md"]
   :schemas []
   :responsibilities
   ["Design fan-out, group consent, and shared conversation state separately from the one-to-one MVP"
    "Avoid overloading messaging-receive@v1 with group semantics"]
   :status :deferred}]

 :out-of-scope
 ["Body encryption in the first MVP+ slice"
  "HTML rendering and active content"
  "Group messaging, CC, or BCC"
  "Live multi-device read/unread push beyond replay"
  "Full multi-device Pseudonym Vault merge"]

 :consumes
 ["message-envelope.v1 artifacts"
  "contact-request.v1 artifacts"
  "local-contact.v1 contact projections"
  "contact-attestation-request.v1 and contact-attestation-result.v1 artifacts"
  "messaging-receive capability passports"
  "Artifact Delivery private-direct and contact lookup send requests"
  "local participant public-handle evidence"
  "Memarium write capability"
  "Pseudonym Vault recovery mirror capability"]

 :produces
 ["Maildir message and draft files"
  "SQLite mailbox and outbox indexes"
  "local contact continuity projections"
  "contacts.membership-changed.v1 facts"
  "messaging.passport-issued.v1 facts"
  "messaging.passport-revoked.v1 facts"
  "messaging.retention-decided.v1 facts"
  "messaging.crisis-marked.v1 facts"
  "messaging.flag.v1 facts"
  "operator notifications with mailbox.open actions"
  "private recovery records for contacts membership and receive-passport refs"]

 :notes
 ["The messaging service owns messaging consent state; the daemon owns authority, signing, and private identity evidence."
  "No generic messaging.fact.v1 wire artifact is introduced in the MVP."
  "The local participant-handle store is separate from address-book contacts to avoid treating UX labels as consent authority."]}
