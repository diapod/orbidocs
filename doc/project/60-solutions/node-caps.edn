{:component/id :orbiplex/node
 :component/title "Orbiplex Node"
 :component/type :runtime
 :component/status :planned

 :summary
 "Primary Orbiplex runtime responsible for room lifecycle, protocol enforcement,
 procurement flow, settlement policy coordination, archival handoff, retrieval,
 and policy-gated local knowledge operations. Settlement-capable deployments may
 additionally attach trusted gateway or escrow roles, but that profile is not
 assumed for every Node."

 :must-implement
 [{:cap/id :peer-identity-discovery-and-session-baseline
   :title "Peer Identity, Discovery, and Session Baseline"
   :kind :transport
   :based-on ["doc/project/40-proposals/002-comm-protocol.md"
              "doc/project/40-proposals/014-node-transport-and-discovery-mvp.md"
              "doc/project/50-requirements/requirements-006.md"]
   :schemas ["node-identity.v1"
             "node-advertisement.v1"
             "peer-handshake.v1"
             "capability-advertisement.v1"]
   :responsibilities
   ["Generate or load a stable local node identity"
    "Derive and expose a stable `node-id`"
    "Publish or consume signed endpoint advertisements"
    "Establish signed peer handshakes and capability exchange over the baseline transport"
    "Maintain keepalive and reconnect behavior for the first networked Node baseline"]
   :status :todo}

  {:cap/id :room-lifecycle
   :title "Question Room Lifecycle"
   :kind :protocol
   :based-on ["doc/project/30-stories/story-001.md"
              "doc/project/30-stories/story-004.md"
              "doc/project/50-requirements/requirements-001.md"]
   :schemas ["question-envelope.v1"
             "answer-room-metadata.v1"
             "response-envelope.v1"]
   :responsibilities
   ["Open or bind a room to `question/id`"
    "Enforce exposure mode and room policy profile"
    "Preserve provenance for room messages and outputs"]
   :status :todo}

  {:cap/id :answer-procurement
   :title "Federated Answer Procurement"
   :kind :protocol
   :based-on ["doc/project/30-stories/story-001.md"
              "doc/project/40-proposals/011-federated-answer-procurement-lifecycle.md"
              "doc/project/50-requirements/requirements-001.md"]
   :schemas ["procurement-offer.v1"
             "procurement-contract.v1"
             "procurement-receipt.v1"]
   :responsibilities
   ["Collect and compare offers"
    "Select responder under policy"
    "Record contract and receipt without coupling to crypto rails"
    "Expose effective gateway and escrow policy context for paid procurement"
    "Suppress or degrade paid procurement paths when settlement disclosures require it"]
   :status :todo}

  {:cap/id :settlement-policy-coordination
   :title "Settlement Policy Coordination and Disclosure Trail"
   :kind :policy-enforcement
   :based-on ["doc/project/40-proposals/016-supervised-prepaid-gateway-and-escrow-mvp.md"
              "doc/project/40-proposals/017-organization-subjects-and-org-did-key.md"
              "doc/project/50-requirements/requirements-007.md"
              "doc/project/50-requirements/requirements-008.md"]
   :schemas ["gateway-policy.v1"
             "escrow-policy.v1"
             "settlement-policy-disclosure.v1"
             "gateway-receipt.v1"
             "ledger-hold.v1"]
   :responsibilities
   ["Ingest and expose active settlement policy references for paid procurement"
    "Retain audit joins from procurement artifacts to settlement policies and disclosure events"
    "Expose degraded, blocked, or manual-review-only settlement states as first-class operational facts"
    "Keep settlement visibility separate from protocol-external payment execution"]
   :status :todo}

  {:cap/id :local-learning
   :title "Local Learning and Knowledge Promotion"
   :kind :policy-enforcement
   :based-on ["doc/project/30-stories/story-002.md"
              "doc/project/50-requirements/requirements-002.md"]
   :schemas ["learning-outcome.v1"
             "knowledge-artifact.v1"]
   :responsibilities
   ["Classify outcomes as confirmed/corrected/unresolved"
    "Promote only policy-accepted outcomes to trusted local retrieval"
    "Keep unresolved material out of trusted retrieval by default"]
   :status :todo}

  {:cap/id :archival-handoff
   :title "Archivist and Vault Handoff"
   :kind :storage
   :based-on ["doc/project/30-stories/story-003.md"
              "doc/project/40-proposals/012-learning-outcomes-and-archival-contracts.md"
              "doc/project/50-requirements/requirements-003.md"]
   :schemas ["archival-package.v1"
             "archivist-advertisement.v1"
             "retrieval-request.v1"
             "retrieval-response.v1"]
   :responsibilities
   ["Prepare archival package with scope, redaction, and integrity metadata"
    "Select archivist under policy"
    "Record retrieval and storage provenance"]
   :status :todo}]

 :may-implement
 [{:cap/id :transcript-monitoring
   :title "Transcript Monitoring"
   :kind :observation
   :based-on ["doc/project/40-proposals/008-transcription-monitors-and-public-vaults.md"
              "doc/project/50-requirements/requirements-004.md"
              "doc/project/50-requirements/requirements-005.md"]
   :schemas ["transcript-segment.v1"
             "transcript-bundle.v1"]
   :responsibilities
   ["Observe only policy-allowed traffic"
    "Preserve human-origin semantics and consent basis"]
   :status :optional}]

 :out-of-scope
 ["Rich end-user UI"
  "Protocol-external payment processing"
  "Direct base-model mutation as default specialization path"]

 :consumes
 ["question-envelope.v1"
  "retrieval-response.v1"
  "archivist-advertisement.v1"
  "gateway-policy.v1"
  "escrow-policy.v1"
  "settlement-policy-disclosure.v1"]

 :produces
 ["answer-room-metadata.v1"
  "response-envelope.v1"
  "learning-outcome.v1"
  "knowledge-artifact.v1"
  "archival-package.v1"]

 :notes
 ["Statuses here are architecture-level, not repo-implementation status."
  "Concrete module/file ownership belongs in the node repository, not in orbidocs."]}
