  {:cap/id :middleware-schema-gate-coverage
   :title "Expanded Middleware Schema Gate Coverage"
   :kind :validation
   :based-on ["node/middleware/README.md"]
   :schemas ["node/middleware/schemas/*.schema.json"]
   :responsibilities
