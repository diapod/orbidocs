   :schemas ["middleware-module-report"]
   :responsibilities
   ["Invoke observers after phase completion even when a dispatch handler short-circuits"
    "Provide post-chain observation over original and effective payloads"
    "Let Memarium and audit modules record facts about the effective result"]
   :status :planned}

  {:cap/id :middleware-operator-ui-extensions
   :title "Middleware Operator UI Extensions"
   :kind :operator-ui
   :based-on ["doc/project/40-proposals/052-tauri-hosted-node-ui.md"
